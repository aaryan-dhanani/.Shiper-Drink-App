<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111625">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/ll_history_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="44dp"
        android:paddingBottom="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="24dp">

            <!-- Back Arrow explicitly styled -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:padding="4dp"
                app:tint="#A8B0C0" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order History"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:gravity="center" />

            <!-- Search icon instead of empty space -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                app:tint="#A8B0C0" />
        </LinearLayout>

        <!-- Dummy Tabs Row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="24dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Orders"
                        android:textColor="#FFB300"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="8dp" />
                    <!-- Highlight line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="#FFB300" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ongoing"
                    android:textColor="#8B93A6"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="#8B93A6"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancelled"
                    android:textColor="#8B93A6"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2E374D" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/ll_history_header"
        android:layout_above="@+id/fake_nav"
        android:text="No orders yet!"
        android:gravity="center"
        android:textColor="#8B93A6"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_orders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/ll_history_header"
        android:layout_above="@+id/fake_nav"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:clipToPadding="false" />

    <!-- Hardcoded Fake Bottom Nav to match mockup 2 -->
    <LinearLayout
        android:id="@+id/fake_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="#161B2A"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <FrameLayout android:id="@+id/nav_shop" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_shop" app:tint="#8B93A6" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SHOP" android:textSize="9sp" android:textColor="#8B93A6" android:fontFamily="sans-serif-bold" android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>
        <FrameLayout android:id="@+id/nav_search" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search" app:tint="#8B93A6" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEARCH" android:textSize="9sp" android:textColor="#8B93A6" android:fontFamily="sans-serif-bold" android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>
        <FrameLayout android:id="@+id/nav_cart" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_cart" app:tint="#8B93A6" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CART" android:textSize="9sp" android:textColor="#8B93A6" android:fontFamily="sans-serif-bold" android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>
        <FrameLayout android:id="@+id/nav_profile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_person" app:tint="#8B93A6" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROFILE" android:textSize="9sp" android:textColor="#8B93A6" android:fontFamily="sans-serif-bold" android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</RelativeLayout>
