<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#1E2538">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- FAKE IMAGE LEFT -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_shiper_image_placeholder"
            android:layout_marginEnd="16dp">
            <!-- You can use actual image if backend works, static for now -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/drink5_citrus_splash"
                android:scaleType="centerCrop" />
            <!-- Inner Corner Cutout for design -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#2E000000" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_cart_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_cart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DBA42A"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Minus Button in dark circle -->
                <FrameLayout
                    android:id="@+id/btn_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_shiper_logo">
                    <!-- assuming bg_shiper_logo is dark rounded bg -->
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_minus"
                        app:tint="#8B93A6" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_cart_quantity"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:gravity="center" />

                <!-- Plus Button in dark circle -->
                <FrameLayout
                    android:id="@+id/btn_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_shiper_logo">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plus"
                        app:tint="#8B93A6" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Hidden Required Views for Java Logic -->
        <ImageButton
            android:id="@+id/btn_remove"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_cart_subtotal"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
